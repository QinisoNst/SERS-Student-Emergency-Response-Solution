/**
 * @fileoverview Firestore Security Rules for the SERS application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Users can only
 * access their own profile data and incident reports. This is achieved
 * primarily through path-based authorization for profiles and document-based
 * authorization for incident reports.
 *
 * Data Structure:
 * - User profiles are stored under `/users/{userId}/profile`.
 * - Incident reports are stored in a top-level collection `/incidentReports/{reportId}`.
 *
 * Key Security Decisions:
 * - User listing is disabled to prevent enumeration.
 * - Read-only collections are not present in this data model.
 * - The default security posture for ambiguous relationships is strict: deny all.
 * - No global admin roles are used, adhering to a purely user-centric access model.
 *
 * Denormalization for Authorization:
 * - The `userId` is stored within each incident report document to enable
 *   document-based access control (DBAC), as path-based ownership is not used
 *   for the top-level `incidentReports` collection.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces access control for user profiles. Only the owner can read, create, update, or delete their profile.
     * @path /users/{userId}/profile
     * @allow (get, create, update, delete) User with UID 'user123' can access /users/user123/profile.
     * @deny (get, create, update, delete) User with UID 'user456' cannot access /users/user123/profile.
     * @principle Enforces document ownership for all operations via path.
     */
    match /users/{userId}/profile {
      // Allow reads only if the user is signed in and owns the profile.
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false; // Listing user profiles is not permitted.

      // Allow creation only if the user is signed in and the userId matches the authenticated user's ID.
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == userId;

      // Allow updates and deletes only if the user is signed in and owns the profile, and the document exists.
      allow update: if isSignedIn() && isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Enforces access control for the top-level incident reports collection.
     * @path /incidentReports/{reportId}
     * @allow (create) Any signed-in user can create a report.
     * @allow (get, update, delete) Only the user who created the report can access it.
     * @allow (list) Any signed in user can list all reports (for admin dashboard).
     * @principle Enforces document ownership for read/write operations via a 'userId' field check (DBAC).
     */
    match /incidentReports/{reportId} {
      // Allow any signed-in user to create a report, as long as they set their own UID correctly.
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && request.resource.data.id == reportId;

      // Allow read, update, and delete only if the user is signed in and is the owner of the document.
      allow get, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // Allow list operations for any signed in user (for admin functionality).
      // In a production app, this should be restricted to admin users.
      allow list: if isSignedIn();
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }
  }
}
