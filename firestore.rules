/**
 * @fileoverview Firestore Security Rules for the SERS application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Users can only
 * access their own profile data and incident reports. This is achieved
 * primarily through path-based authorization.
 *
 * Data Structure:
 * - User profiles are stored under `/users/{userId}/profile`.
 * - Incident reports are stored under `/users/{userId}/incidentReports/{reportId}`.
 *
 * Key Security Decisions:
 * - User listing is disabled to prevent enumeration.
 * - Read-only collections are not present in this data model.
 * - The default security posture for ambiguous relationships is strict: deny all.
 * - No global admin roles are used, adhering to a purely user-centric access model.
 *
 * Denormalization for Authorization:
 * - No denormalization is required as path-based ownership provides sufficient authorization context. The `userId` is implicit in the path.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces access control for user profiles. Only the owner can read, create, update, or delete their profile.
     * @path /users/{userId}/profile
     * @allow (get, create, update, delete) User with UID 'user123' can access /users/user123/profile.
     * @deny (get, create, update, delete) User with UID 'user456' cannot access /users/user123/profile.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/profile {
      // Allow reads only if the user is signed in and owns the profile.
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false; // Listing user profiles is not permitted.

      // Allow creation only if the user is signed in and the userId matches the authenticated user's ID.
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == userId;

      // Allow updates and deletes only if the user is signed in and owns the profile, and the document exists.
      allow update: if isSignedIn() && isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Enforces access control for incident reports. Only the owner (user who created the report) can read, create, update, or delete it.
     * @path /users/{userId}/incidentReports/{reportId}
     * @allow (get, create, update, delete) User with UID 'user123' can access /users/user123/incidentReports/report456.
     * @deny (get, create, update, delete) User with UID 'user456' cannot access /users/user123/incidentReports/report456.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/incidentReports/{reportId} {
      // Allow reads only if the user is signed in and owns the report.
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId); // Allow owner to list their own reports.

      // Allow creation only if the user is signed in and the userId matches the authenticated user's ID.
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.userId == userId && request.resource.data.id == reportId;

      // Allow updates and deletes only if the user is signed in and owns the report, and the document exists.
      allow update: if isSignedIn() && isExistingOwner(userId) && request.resource.data.userId == resource.data.userId && request.resource.data.id == resource.data.id;
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }
  }
}